{
  "project": {
    "name": "LifeOS",
    "description": "LifeOS — universal guardrails for all phases (A→H). Apply‑Mode prompts define phase scope."
  },

  "rules": {
    "minimalDiff": true,
    "askBeforeLargeChanges": true,
    "neverIntroduceDependencies": true,
    "neverModifyUnrelatedFiles": true,
    "neverMoveFiles": true,
    "neverRenameFiles": true,

    "featureStructure": {
      "enforce": true,
      "folders": [
        "components",
        "pages",
        "hooks",
        "selectors",
        "store",
        "api.ts"
      ]
    },

    "publicBoundary": {
      "enforce": true,
      "apiFile": "api.ts",
      "message": "Always import from @/features/<feature>/api. Never reach into selectors/, store/, or domain/ from outside the feature."
    },

    "allowedChanges": [
      "updateImportsToUsePublicBoundary",
      "addSelectors",
      "stabilizeHookOutputs",
      "wrapActionsInUseMemo",
      "fixRegressions",
      "cleanDeadCode",
      "applyPhaseSpecificTasks"
    ],

    "disallowedChanges": [
      "rewriteReducers",
      "addGlobalState",
      "crossFeatureImports",
      "modifyDesignSystem",
      "introduceNewUIPrimitives"
    ],

    "responseStyle": {
      "summaries": false,
      "technical": true,
      "concise": true,
      "askForConfirmation": true
    }
  }
}
