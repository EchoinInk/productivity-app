{
  "project": {
    "name": "Lumo",
    "description": "Lumo — mobile-first life system app. Feature-based architecture with strict UI/design system boundaries."
  },

  "rules": {
    "minimalDiff": true,
    "askBeforeLargeChanges": true,

    "neverIntroduceDependencies": true,
    "neverModifyUnrelatedFiles": true,

    "allowRefactor": true,
    "allowFileMoves": true,
    "allowRenames": true,

    "featureStructure": {
      "enforce": true,
      "folders": [
        "components",
        "containers",
        "hooks",
        "selectors",
        "store",
        "api.ts",
        "types.ts"
      ]
    },

    "publicBoundary": {
      "enforce": false,
      "apiFile": "api.ts",
      "message": "Prefer importing from @/features/<feature>/api, but allow direct selector/store usage during refactor phase."
    },

    "designSystem": {
      "enforce": true,
      "location": "/src/components/ui",
      "rules": [
        "noRawHex",
        "noTailwindDefaultColors",
        "tokensOnly",
        "noBusinessLogicInUI"
      ]
    },

    "allowedChanges": [
      "updateImportsToUsePublicBoundary",
      "addSelectors",
      "stabilizeHookOutputs",
      "wrapActionsInUseMemo",
      "fixRegressions",
      "cleanDeadCode",
      "applyPhaseSpecificTasks",
      "createDesignSystem",
      "refactorUIComponents"
    ],

    "disallowedChanges": [
      "rewriteReducers",
      "addGlobalState",
      "crossFeatureImports"
    ],

    "responseStyle": {
      "summaries": false,
      "technical": true,
      "concise": true,
      "askForConfirmation": true
    }
  }
}